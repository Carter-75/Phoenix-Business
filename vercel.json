{
  "version": 2,
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "angular"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/api"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors *"
        },
        {
          "key": "Cross-Origin-Resource-Policy",
          "value": "cross-origin"
        }
    }
  ],
  "crons": [
    {
      "path": "/api/cron/check-refunds",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/daily-renewals",
      "schedule": "0 8 * * *"
    }
  ]
}